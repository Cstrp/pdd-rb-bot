# PostgreSQL connection string (required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/pdd_rb?schema=public"

# Telegram Bot Token (required)
# Get it from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN="1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# OpenAI API Key (required)
# Used for: text-embedding-3-small (indexing) + gpt-4o-mini (answers + Vision OCR)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."

# Tavily API Key (optional)
# Enables web search grounding — answers are cross-checked against internet sources
# Without this key, the bot falls back to RAG-only mode (still fully functional)
# Free tier available at: https://app.tavily.com
TAVILY_API_KEY="tvly-..."

# Admin Telegram ID (optional, but strongly recommended)
# The Telegram user ID that has full admin access to bot commands (/ban, /unban, /users, etc.)
# Default fallback: 620756711
ADMIN_TELEGRAM_ID=620756711
